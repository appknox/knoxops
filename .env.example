# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://knoxadmin:knoxadmin@localhost:5432/knoxadmin

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (for invites)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@knoxadmin.local


# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# OIDC (Google SSO)
OIDC_CLIENT_ID=<your-google-oauth-client-id>
OIDC_CLIENT_SECRET=<your-google-oauth-client-secret>
OIDC_ISSUER=https://accounts.google.com
OIDC_CALLBACK_URL=http://localhost:3000/api/auth/oidc/callback

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
