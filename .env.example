# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://knoxadmin:knoxadmin@localhost:5432/knoxadmin

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (for invites)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@knoxadmin.local


# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# OIDC (Google SSO)
OIDC_CLIENT_ID=<your-google-oauth-client-id>
OIDC_CLIENT_SECRET=<your-google-oauth-client-secret>
OIDC_ISSUER=https://accounts.google.com
OIDC_CALLBACK_URL=http://localhost:3000/api/auth/oidc/callback

# Invite Expiry
INVITE_EXPIRY_DAYS=5

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/ONPREM/WEBHOOK/URL
SLACK_DEVICE_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/DEVICE/WEBHOOK/URL
# Sale notifications — configure via Settings UI in the dashboard

# GitHub (release management, optional)
GITHUB_TOKEN=
GITHUB_OWNER=appknox
GITHUB_REPO=

# Migrations (docker-compose only)
# Set to "true" to auto-run migrations on container start
# Leave unset in k8s — run migrations manually via kubectl exec
RUN_MIGRATIONS=true
