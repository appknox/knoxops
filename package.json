{
  "name": "knoxadmin",
  "version": "1.0.0",
  "description": "Internal admin tool API for device and on-prem management",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "tsx src/db/seed.ts",
    "test": "DATABASE_URL=${TEST_DATABASE_URL:-postgres://admin:admin123@localhost:5432/knoxadmin_test} vitest",
    "test:run": "DATABASE_URL=${TEST_DATABASE_URL:-postgres://admin:admin123@localhost:5432/knoxadmin_test} vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@aws-sdk/s3-request-presigner": "^3.1022.0",
    "@casl/ability": "^6.7.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@slack/webhook": "^7.0.7",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "ios-device-list": "^1.1.37",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
